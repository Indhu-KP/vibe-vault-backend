# Server
PORT=3000

# Use Supabase Transaction Pooler URI (recommended for Vercel and restricted networks)
# Example format only; replace with your real value from Supabase Dashboard -> Connect -> Pooling
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:<PASSWORD>@<POOLER-HOST>:6543/postgres

# Optional fallback if you do not use SUPABASE_POOLER_URL
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres

# Frontend
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<publishable-key>
